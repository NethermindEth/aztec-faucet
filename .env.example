# L1 Configuration
L1_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
L1_CHAIN_ID=11155111
FAUCET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# L2 Configuration
AZTEC_NODE_URL=https://v4-devnet-2.aztec-labs.com/
SPONSORED_FPC_ADDRESS=0x09a4df73aa47f82531a038d1d51abfc85b27665c4b7ca751e2d4fa9f19caffb2

# Faucet Settings
# ETH sent per request (Sepolia). 0.001 covers thousands of L1 txs.
ETH_DRIP_AMOUNT=0.001
# Fee Juice bridged per request (L2). The Fee Juice Portal contract requires a minimum of 1000 FJ per bridge call.
# Set to 1000000000000000000000 (1000 FJ = 1000 * 10^18 motes).
FEE_JUICE_DRIP_AMOUNT=1000000000000000000000
# Rate limit: 24 hours per address per asset (one drip per day).
# 1 FJ/day is more than enough — a developer burns through ~0.001 FJ in a heavy session.
DRIP_INTERVAL_MS=86400000
# IP-based rate limit: 1 hour, tighter than address-based to resist address generation abuse.
# Defaults to DRIP_INTERVAL_MS if not set.
IP_DRIP_INTERVAL_MS=3600000

# Cloudflare Turnstile (get keys at https://dash.cloudflare.com/turnstile)
# Leave empty to skip CAPTCHA in development
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

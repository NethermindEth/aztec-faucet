# L1 Configuration (shared — both networks run on Sepolia)
L1_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
L1_CHAIN_ID=11155111
FAUCET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ── Devnet ────────────────────────────────────────────────────────────────────
# L2 node — optional, public defaults used if unset
# DEVNET_AZTEC_NODE_URL=https://v4-devnet-2.aztec-labs.com/
# DEVNET_SPONSORED_FPC_ADDRESS=0x09a4df73aa47f82531a038d1d51abfc85b27665c4b7ca751e2d4fa9f19caffb2
# Fee Juice per drip — default: 1000 FJ (portal contract minimum)
# DEVNET_FEE_JUICE_DRIP_AMOUNT=1000000000000000000000

# ── Testnet ───────────────────────────────────────────────────────────────────
# L2 node — optional, public defaults used if unset
# TESTNET_AZTEC_NODE_URL=https://rpc.testnet.aztec-labs.com
# TESTNET_SPONSORED_FPC_ADDRESS=0x19b5539ca1b104d4c3705de94e4555c9630def411f025e023a13189d0c56f8f2
# Fee Juice per drip — default: 100 FJ (covers deploy + claim gas; keeps pre-funded wallet healthy)
# TESTNET_FEE_JUICE_DRIP_AMOUNT=100000000000000000000

# ── Shared Settings ───────────────────────────────────────────────────────────
# ETH sent per request (Sepolia L1). 0.001 covers thousands of L1 txs.
ETH_DRIP_AMOUNT=0.001
# Rate limit: one drip per address per asset per 24 hours.
DRIP_INTERVAL_MS=86400000
# IP-based rate limit: 1 hour, tighter than address-based to resist address generation abuse.
# Defaults to DRIP_INTERVAL_MS if not set.
IP_DRIP_INTERVAL_MS=3600000

# Cloudflare Turnstile (get keys at https://dash.cloudflare.com/turnstile)
# Leave empty to skip CAPTCHA in development
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Microsoft Clarity heatmap/session tracking (leave unset to disable)
# Injected at build time via CI for production only
NEXT_PUBLIC_CLARITY_TAG_ID=

# ── Legacy (deprecated) ───────────────────────────────────────────────────────
# Use DEVNET_FEE_JUICE_DRIP_AMOUNT instead. Kept as devnet-only fallback.
# FEE_JUICE_DRIP_AMOUNT=1000000000000000000000
# AZTEC_NODE_URL=https://v4-devnet-2.aztec-labs.com/
# SPONSORED_FPC_ADDRESS=0x09a4df73aa47f82531a038d1d51abfc85b27665c4b7ca751e2d4fa9f19caffb2

# Required secrets (never commit real values)
FAUCET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
L1_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional rate-limit overrides — production defaults live in src/lib/network-config.ts.
# In dev, set DRIP_INTERVAL_MS=0 to disable rate limiting entirely.
# DRIP_INTERVAL_MS=28800000        # 8h drip cooldown (prod default)
# DRIP_MAX_PER_ADDRESS=3           # drips per cooldown per address (prod default)
# DRIP_MAX_PER_IP=6                # drips per cooldown per IP (prod default)
# KEYGEN_INTERVAL_MS=86400000      # 24h keygen cooldown (prod default)
# KEYGEN_MAX_PER_IP=20             # keygens per cooldown per IP (prod default)

# Optional analytics (omit to disable)
# NEXT_PUBLIC_CLARITY_TAG_ID=

# Build-time only (used by client to build raw GitHub URLs)
# NEXT_PUBLIC_GITHUB_BRANCH=main
